{
    "name": "verturin/missingtopicauthor",
    "type": "phpbb-extension",
    "description": "Display an alert banner on topics when the author is missing or inactive",
	"homepage": "https://github.com/verturin/missingtopicauthor",
    "version": "1.1.0",
    "keywords": ["phpbb", "extension", "topic", "author", "inactive"],
    "license": "GPL-2.0-only",
    "authors": [
        {
            "name": "verturin",
			"homepage": "https://github.com/verturin",											 
            "role": "Lead Developer"
        }
    ],
    "require": {
        "php": ">=7.2",
        "composer/installers": "~1.0 || ~2.0"
    },
    "extra": {
        "display-name": "Message sans utilisateur",
        "soft-require": {
            "phpbb/phpbb": ">=3.3.0,<4.0.0@dev"
        },
		"version-check": {
			"host": "verturin.github.io",
			"directory": "/missingtopicauthor",
			"filename": "missingtopicauthor_version.json",
			"ssl": true
		}		
        
    }
}
